rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /submissions/{document} {
      allow read, write: if true;
    }
    
    match /advertiser_submissions/{document} {
      allow read, write: if true;
    }
    
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
